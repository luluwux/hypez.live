generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Server {
  id                     String          @id @default(uuid())
  ownerId                String
  name                   String
  description            String?
  icon                   String?
  banner                 String?
  memberCount            Int             @default(0)
  activeMemberCount      Int             @default(0)
  boostCount             Int             @default(0)
  voiceMemberCount       Int             @default(0)
  weeklyVoiceMinutes     Int             @default(0)
  weeklyMessageCount     Int             @default(0)
  streamingMemberCount   Int             @default(0)
  videoMemberCount       Int             @default(0)
  normalVoiceMemberCount Int             @default(0)
  channelCount           Int             @default(0)
  voiceChannelCount      Int             @default(0)
  roleCount              Int             @default(0)
  emojiCount             Int             @default(0)
  stickerCount           Int             @default(0)
  isPremium              Boolean         @default(false)
  premiumTier            PremiumTier     @default(NONE)
  premiumExpiresAt       DateTime?       // Null = kalıcı premium
  isVisible              Boolean         @default(false) // False = listeden gizli
  isToken                Boolean         @default(false) // TOKEN rozeti
  nsfw                   Boolean         @default(false) // NSFW sunucu
  isBlacklisted          Boolean         @default(false)
  blacklistReason        String?
  isFlagged              Boolean         @default(false)
  totalHypes             Int             @default(0)
  badges                 String[]
  categories             String[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  votes                  Int             @default(0)
  lastVoterId            String?
  lastVotedAt            DateTime?
  leaderboardChannelId   String?
  leaderboardMessageId   String?
  locale                 String          @default("en")
  inviteUrl              String?         // Discord davet linki
  weeklyHypeScore        Float           @default(0)
  totalHypeScore         Float           @default(0)
  version                Int             @default(0)   // optimistic locking
  emojis                 ServerEmoji[]
  stats                  ServerStats[]
  stickers               ServerSticker[]
  voteHistory            Vote[]
  hypeHistory            HypeVote[]
  applications           Application[]
  premiumCodes           PremiumCode[]

  @@index([isVisible, isBlacklisted])
  @@index([isPremium, votes(sort: Desc)])
  @@index([categories])
  @@index([ownerId])
  @@index([votes(sort: Desc)])
  @@index([weeklyHypeScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model Vote {
  id             String   @id @default(uuid())
  userId         String
  guildId        String
  cachedUsername String?
  cachedAvatar   String?
  createdAt      DateTime @default(now())
  server         Server   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, guildId, createdAt])
  @@index([guildId, createdAt])
}

model HypeVote {
  id        String   @id @default(uuid())
  userId    String
  serverId  String
  weekYear  String   // Format: "2025-W20" (ISO hafta)
  usedAt    DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekYear])
  @@index([serverId, weekYear])
  @@index([userId, usedAt])
}

model ServerStats {
  id           String   @id @default(uuid())
  serverId     String
  voiceCount   Int      @default(0)
  messageCount Int      @default(0)
  recordedAt   DateTime @default(now())
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, recordedAt])
}

model ServerEmoji {
  id        String   @id @default(uuid())
  serverId  String
  emojiId   String
  name      String
  url       String
  animated  Boolean  @default(false)
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, emojiId])
}

model ServerSticker {
  id        String   @id @default(uuid())
  serverId  String
  stickerId String
  name      String
  url       String
  format    String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, stickerId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  displayName   String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  banner        String?
  premiumLevel  Int       @default(0)
  role          String    @default("USER")
  hypePoints    Int       @default(0)
  trustScore    Int       @default(50)
  occupation    String?
  gender        String?
  location      String?
  birthday      DateTime?
  about         String?
  socialLinks   Json?
  isPublished   Boolean   @default(false)
  badges        String[]  @default([])
  profileViews  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  votes         Vote[]
  receivedLikes ProfileLike[] @relation("likedUser")
  givenLikes    ProfileLike[] @relation("likerUser")
  hypeVotes     HypeVote[]
  applications  Application[]
  premiumCodes  PremiumCode[]

  @@map("users")
}

model ProfileLike {
  id        String   @id @default(cuid())
  userId    String
  likerId   String
  createdAt DateTime @default(now())
  user      User     @relation("likedUser", fields: [userId], references: [id], onDelete: Cascade)
  liker     User     @relation("likerUser", fields: [likerId], references: [id], onDelete: Cascade)

  @@unique([userId, likerId])
  @@index([userId])
  @@map("profile_likes")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum PremiumTier {
  NONE
  PREMIUM
  TOKEN
}

enum VerificationMode {
  LOGIC
  VISUAL
  IDENTITY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
}

model VerificationSession {
  id        String             @id @default(uuid())
  userId    String
  serverId  String
  mode      VerificationMode
  status    VerificationStatus @default(PENDING)
  challengeData Json?
  expiresAt DateTime
  createdAt DateTime           @default(now())

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String   // The ID of the admin who performed the action
  action    String   // e.g. "UPDATE_SERVER_PREMIUM", "DELETE_SERVER"
  entityId  String?  // e.g. Server ID or User ID being modified
  details   String?  // JSON stringified details of the change
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt(sort: Desc)])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#6366f1")
  emoji     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tags")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  emoji     String   @default("📁")
  color     String   @default("#6366f1")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?
  color       String   @default("#6366f1")
  description String?
  targetType  String   @default("USER") // USER or SERVER
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("badges")
}

enum ApplicationType {
  PARTNER
  VERIFIED
  STREAMER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Application {
  id            String            @id @default(cuid())
  discordUserId String            // Raw Discord snowflake — used for DM notifications
  userId        String?           // Internal User.id (null if user has no web account)
  guildId       String?           // Server.id (Discord guild ID) — required for PARTNER type
  type          ApplicationType
  status        ApplicationStatus @default(PENDING)
  answers       Json              // Structured Q&A from the Discord modal
  reviewedBy    String?           // Admin's Discord user ID
  reviewNote    String?
  cooldownUntil DateTime?         // Set to now()+30d on rejection to enforce cooldown
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  server Server? @relation(fields: [guildId], references: [id], onDelete: SetNull)

  @@index([discordUserId])
  @@index([status, type])
  @@index([guildId])
  @@index([createdAt(sort: Desc)])
  @@map("applications")
}

model BotSettings {
  id               String   @id @default(uuid())
  botName          String   @default("Moderasyon Bot")
  prefix           String   @default("!")
  description      String?  @default("Sunucu moderasyonu ve güvenlik özellikleri sağlar")
  token            String?
  autoStart        Boolean  @default(true)
  avatar           String?  @default("https://cdn.discordapp.com/embed/avatars/0.png")
  status           String   @default("ONLINE")
  commandLogs      Boolean  @default(true)
  errorLogs        Boolean  @default(true)
  apiLogs          Boolean  @default(false)
  systemLogs       Boolean  @default(true)
  logLevel         String   @default("INFO")
  logRetentionDays Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("bot_settings")
}

model BotCommand {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  category    String   // Moderasyon, Müzik, Genel, Ekonomi vb.
  usage       String
  cooldown    String   @default("Yok") // "5s", "3s", "Yok" vb.
  isActive    Boolean  @default(true)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bot_commands")
}

model BotPermission {
  id          String   @id @default(uuid())
  key         String   @unique // e.g. ADMINISTRATOR, MANAGE_GUILD
  name        String
  description String
  category    String   // Kritik, Yönetim, Moderasyon, Temel, Ses vb.
  isDangerous Boolean  @default(false)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bot_permissions")
}

model BotLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  level     String   // INFO, WARN, ERROR, DEBUG
  category  String   // System, Command, API, Error vb.
  message   String
  user      String?  // e.g. john_doe#1234
  createdAt DateTime @default(now())

  @@map("bot_logs")
}

model SystemSettings {
  id               String   @id @default("global")
  siteName         String   @default("Hypez")
  siteUrl          String   @default("https://hypez.live")
  siteDescription  String   @default("Discord botlarınızı kolayca yönetin ve özelleştirin")
  adminEmail       String   @default("admin@hypez.live")
  supportEmail     String   @default("support@hypez.live")
  defaultLanguage  String   @default("tr")
  timezone         String   @default("Europe/Istanbul")
  currency         String   @default("TRY")
  maintenanceMode  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("system_settings")
}

model PremiumCode {
  id           String    @id @default(uuid())
  code         String    @unique
  duration     Int       // in days
  isUsed       Boolean   @default(false)
  usedById     String?   // The User.id who redeemed it
  usedAt       DateTime?
  usedServerId String?   // The Server.id it was redeemed for
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User?     @relation(fields: [usedById], references: [id], onDelete: SetNull)
  server       Server?   @relation(fields: [usedServerId], references: [id], onDelete: SetNull)

  @@index([code])
  @@map("premium_codes")
}
