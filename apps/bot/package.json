{
    "name": "bot",
    "version": "1.0.0",
    "main": "src/index.ts",
    "scripts": {
        "build": "tsc",
        "start": "node dist/shard.js",
        "start:worker": "node dist/worker.js",
        "dev": "npx tsx watch src/shard.ts",
        "dev:worker": "npx tsx watch src/worker.ts",
        "test": "jest"
    },
    "dependencies": {
        "@hypez/shared-types": "*",
        "@napi-rs/canvas": "^0.1.100",
        "@prisma/client": "^6.19.0",
        "bullmq": "^5.66.5",
        "discord-api-types": "^0.37.70",
        "discord.js": "^14.14.1",
        "dotenv": "^16.3.1",
        "ioredis": "^5.9.1",
        "pino": "^10.2.0",
        "pino-pretty": "^13.1.3"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.10.6",
        "jest": "^30.0.0",
        "nodemon": "^3.0.2",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "tsx": "^4.22.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "moduleNameMapper": {
            "^@hypez/shared-types$": "<rootDir>/../../../packages/shared-types/src/index.ts",
            "^(\\.{1,2}/.*)\\.js$": "$1"
        }
    }
}
