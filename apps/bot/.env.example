# Discord Bot Token
DISCORD_TOKEN="your_discord_bot_token"

# Hypez API base URL
API_URL="http://localhost:3001/api"

# ─── Secret Generation ──────────────────────────────────────────────────────
# BOT_SECRET must be at least 32 characters and must match BOT_SECRET in apps/api/.env.
# Generate one with:
#   node -e "require('crypto').randomBytes(32).toString('hex')"
# ────────────────────────────────────────────────────────────────────────────

# Shared secret for bot-to-API authentication — must match BOT_SECRET in apps/api/.env
BOT_SECRET="replace-with-a-64-char-hex-string"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# Bot owner Discord ID (restricts /devmode command and dev bypass)
OWNER_ID="your_discord_user_id"
DEV_OWNER_ID="your_discord_user_id"
