# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Redis connection string (use rediss:// for TLS)
REDIS_URL="redis://localhost:6379"

# ─── Secret Generation ──────────────────────────────────────────────────────
# All secrets below must be at least 32 characters and cryptographically random.
# Generate one with:
#   node -e "require('crypto').randomBytes(32).toString('hex')"
#
# IMPORTANT: JWT_SECRET and AUTH_SECRET must be DIFFERENT values.
# Sharing them means a compromise of one leaks both the NextAuth session and
# the backend API token simultaneously.
# ────────────────────────────────────────────────────────────────────────────

# JWT signing secret — used by the NestJS API to sign/verify bearer tokens
# Must NOT match AUTH_SECRET in the web app
JWT_SECRET="replace-with-a-64-char-hex-string"

# Shared secret for bot-to-API authentication
# Must be at least 32 characters
BOT_SECRET="replace-with-a-64-char-hex-string"

# Admin dashboard API key
# Must be at least 32 characters — avoid dictionary words or predictable patterns
ADMIN_API_KEY="replace-with-a-64-char-hex-string"

# Discord OAuth credentials (from discord.com/developers/applications)
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_TOKEN="your_discord_bot_token"

# Allowed CORS origins (comma-separated, no trailing slashes)
CORS_ORIGINS="https://yourdomain.com,http://localhost:3000"

# WebSocket allowed origin(s) for the live events gateway (comma-separated)
WEB_URL="https://yourdomain.com"
