# ==========================================
# Hypez Environment Variables Example
# ==========================================

# 1. DATABASE (Prisma)
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# 2. REDIS (BullMQ & Leaderboard)
# Redis connection URL (e.g. Upstash, local redis)
REDIS_URL="redis://localhost:6379"

# 3. DISCORD BOT & OAUTH
# Discord Developer Portal'dan alınacak
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_TOKEN=""

# 4. AUTH & SECURITY
# NextAuth.js (Auth.js) gizli anahtarı - Güvenli rastgele bir dizi (min 32 karakter)
AUTH_SECRET="super_secret_auth_key_replace_me"
# API güvenliği için Admin Proxy key'i (min 32 karakter)
ADMIN_API_KEY="super_secret_admin_key_replace_me"
# Backend tarafındaki bot endpointlerini koruyan key
BOT_SECRET="super_secret_bot_key_replace_me"
# JWT şifreleme (API auth için gerekirse)
JWT_SECRET="super_secret_jwt_key_replace_me"
JWT_EXPIRES_IN="7d"

# 5. FRONTEND & NEXT.JS
# NextAuth domain ayarı
NEXTAUTH_URL="http://localhost:3000"
# Admin Dashboard'a erişebilen Discord kullanıcı ID'leri (virgülle ayırın)
NEXT_PUBLIC_ADMIN_DISCORD_IDS="123456789012345678"
# Frontend'in backend'e proxy isteği atacağı URL
NEXT_PUBLIC_API_URL="http://127.0.0.1:3001/api"

# 6. APP CONFIGURATION
# Sunucu oy bekleme süresi (Saat)
VOTE_COOLDOWN_HOURS=12
# Ortam (development / production)
NODE_ENV="development"
# CORS İzin verilen adresler (virgülle ayrılmış)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# 7. LOGGING (Optional)
# Logtail vb. harici log servisleri için
BETTER_STACK_TOKEN=""
LOG_LEVEL="info"
